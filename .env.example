# ==============================================
# PromptX 环境变量示例
# ==============================================
# 注意：API Key 无需在此配置，请直接在应用内
# 「API 配置」页面设置，数据仅保存在浏览器本地。
#
# 支持的 AI 服务商：
#   - Google Gemini
#   - DeepSeek
#   - OpenAI（及所有兼容 OpenAI 协议的接口）
# ==============================================

# GEMINI_API_KEY: 可在此处设置本地开发时默认使用的 API Key。
# 生产环境（GitHub Pages）下，用户通过前端设置页面配置。
GEMINI_API_KEY="YOUR_API_KEY"

# APP_URL: 应用部署地址。
APP_URL="http://localhost:3000"
